
# SaaS Team Workspace API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_workspace?schema=public"

# JWT
# Required, and must be at least 32 characters — the server refuses to start
# otherwise. Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt
BCRYPT_ROUNDS=12

# Redis (optional — used for token blacklisting and caching)
#
# Token blacklisting controls logout security:
#
# REDIS_ENABLED=true
#   Uses Redis blacklist.
#   Required for production and multi-instance deployments.
#   Blacklisted tokens are shared across all application instances.
#
# REDIS_ENABLED=false
#   Uses an in-memory blacklist.
#   Safe for local development and single-instance staging.
#   Blacklisted tokens are NOT shared between instances and
#   are cleared when the server restarts.
#
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX=10
# Per-account (email-keyed) limiter on /login, catches credential stuffing
# that rotates source IPs while targeting the same account
AUTH_ACCOUNT_RATE_LIMIT_WINDOW_MS=900000
AUTH_ACCOUNT_RATE_LIMIT_MAX=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Invitation
INVITATION_EXPIRES_IN_DAYS=7
INVITATION_CLEANUP_INTERVAL_MS=3600000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Email (optional — uses Ethereal test account in development)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@saasworkspace.com
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# App
APP_BASE_URL=http://localhost:3000
